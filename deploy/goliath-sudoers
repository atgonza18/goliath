# Allow goliath user to manage goliath services without password
# Install: sudo cp /opt/goliath/deploy/goliath-sudoers /etc/sudoers.d/goliath && sudo chmod 440 /etc/sudoers.d/goliath
goliath ALL=(root) NOPASSWD: /usr/bin/systemctl restart goliath-bot, /usr/bin/systemctl restart goliath-web, /usr/bin/systemctl stop goliath-bot, /usr/bin/systemctl stop goliath-web, /usr/bin/systemctl start goliath-bot, /usr/bin/systemctl start goliath-web, /usr/bin/systemctl status goliath-bot, /usr/bin/systemctl status goliath-web, /usr/bin/systemctl daemon-reload, /usr/bin/cp /opt/goliath/deploy/goliath-bot.service /etc/systemd/system/goliath-bot.service, /usr/bin/cp /opt/goliath/web-platform/goliath-web.service /etc/systemd/system/goliath-web.service, /usr/bin/journalctl -u goliath-bot *, /usr/bin/journalctl -u goliath-web *
