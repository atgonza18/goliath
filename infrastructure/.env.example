# =============================================================================
# Goliath App Builder — Infrastructure Environment Variables
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env && nano .env
# =============================================================================

# Your domain name (REQUIRED)
# All apps will be deployed at: appname.GOLIATH_DOMAIN
# Example: GOLIATH_DOMAIN=goliath.example.com
#   → hello.goliath.example.com, myapp.goliath.example.com, etc.
GOLIATH_DOMAIN=

# Email for Let's Encrypt SSL certificates (REQUIRED)
# Let's Encrypt sends expiration notices to this email
ACME_EMAIL=

# Traefik dashboard auth (OPTIONAL)
# Generate with: htpasswd -nb admin yourpassword
# The dollar signs must be doubled ($$) in docker-compose
# Example: admin:$$apr1$$ruca84Hq$$mbjdMZBAG.KWn7vfN/SNK/
TRAEFIK_DASHBOARD_AUTH=
